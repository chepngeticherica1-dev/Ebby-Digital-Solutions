# ======================================

# EBBY DIGITAL SOLUTIONS ENVIRONMENT

# ======================================

APP_NAME="Ebby Digital Solutions"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# ======================================

# DATABASE

# ======================================

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ebby_digital
DB_USERNAME=root
DB_PASSWORD=

# ======================================

# FILE UPLOADS

# ======================================

UPLOAD_PATH=uploads/
MAX_FILE_SIZE=10485760

# ======================================

# EMAIL

# ======================================

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=[your-email@gmail.com](mailto:your-email@gmail.com)
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=[your-email@gmail.com](mailto:your-email@gmail.com)
MAIL_FROM_NAME="Ebby Digital Solutions"

# ======================================

# MPESA (FUTURE)

# ======================================

MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa-callback.php

# ======================================

# SECURITY

# ======================================

JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY
SESSION_TIMEOUT=3600
